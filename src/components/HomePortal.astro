---
// Thin homepage orchestrator: resolves the bilingual copy model and composes
// the editorial sections in order. All styling lives in HomeStyles.astro.
import { getHomeCopy, type HomeLocale } from "../lib/home-copy";
import HomeHero from "./home/HomeHero.astro";
import HomeGoalNavigator from "./home/HomeGoalNavigator.astro";
import HomeFieldGuide from "./home/HomeFieldGuide.astro";
import HomeFeaturedGuides from "./home/HomeFeaturedGuides.astro";
import HomeTrustEvidence from "./home/HomeTrustEvidence.astro";
import HomeClosingCta from "./home/HomeClosingCta.astro";

interface Props {
  locale: HomeLocale;
}

const { locale } = Astro.props;
const copy = getHomeCopy(locale);
---

<div class="home-portal">
  <HomeHero copy={copy.hero} />
  <HomeGoalNavigator copy={copy.navigator} />
  <HomeFieldGuide copy={copy.fieldGuide} />
  <HomeFeaturedGuides copy={copy.guides} />
  <HomeTrustEvidence copy={copy.trust} />
  <section class="home-section home-news" aria-labelledby="home-news-title">
    <div class="home-section__heading">
      <p class="home-eyebrow">{copy.news.eyebrow}</p>
      <h2 id="home-news-title">{copy.news.title}</h2>
    </div>
    <slot name="editorial-news" />
  </section>
  <HomeClosingCta copy={copy.closing} />
</div>
