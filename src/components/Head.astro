---
import Default from "@astrojs/starlight/components/Head.astro";

type HeadEntry = {
  tag: string;
  attrs?: Record<string, string | boolean>;
  content?: string;
};

const siteUrl = "https://smartbolig.net";
const pathname = Astro.url.pathname;
const pageUrl = new URL(pathname, siteUrl).href;
const lang = pathname.startsWith("/en/") ? "en" : "da";
const isNotFoundPage = /^\/(?:da\/|en\/)?404\/?$/.test(pathname);
const defaultSocialImageUrl = `${siteUrl}/images/og-image.png`;
const organizationLogoUrl = `${siteUrl}/brand/logo/logo-dark-1200x270.png`;
const aiNewsSocialImageUrl = `${siteUrl}/images/ai-news-og.png`;
const aiNewsSchemaImages = [
  { url: `${siteUrl}/images/ai-news-og-16x9.png`, width: 1200, height: 675 },
  { url: `${siteUrl}/images/ai-news-og-4x3.png`, width: 1200, height: 900 },
  { url: `${siteUrl}/images/ai-news-og-1x1.png`, width: 1200, height: 1200 },
];

let starlightRoute: typeof Astro.locals.starlightRoute | null = null;

try {
  starlightRoute = Astro.locals.starlightRoute;
} catch {
  starlightRoute = null;
}

// Get page data with fallbacks for 404 page and custom Starlight head props.
const entry = Astro.props.entry || starlightRoute?.entry;
const lastUpdated = Astro.props.lastUpdated || starlightRoute?.lastUpdated;
const title = entry?.data?.title || (isNotFoundPage
  ? lang === "da" ? "404 - Side ikke fundet" : "404 - Page not found"
  : "SmartBolig.net");
const description = entry?.data?.description || (isNotFoundPage
  ? lang === "da"
    ? "Siden blev ikke fundet. Find SmartBolig.net guides fra forsiden."
    : "Page not found. Find SmartBolig.net guides from the homepage."
  : "Dansk guide til smart home");

const toIsoDate = (...values: unknown[]) => {
  for (const value of values) {
    if (!value || typeof value === "boolean") continue;
    const date = new Date(value as string | number | Date);
    if (!Number.isNaN(date.getTime())) return date.toISOString();
  }
  return null;
};

const languageCode = lang === "da" ? "da-DK" : "en-US";
const openGraphLocale = lang === "da" ? "da_DK" : "en_US";
const alternateOpenGraphLocale = lang === "da" ? "en_US" : "da_DK";
const isAiNewsPage = /^\/(?:da|en)\/ai\/nyheder(?:\/|$)/.test(pathname);
const isAiNewsArticle = /^\/(?:da|en)\/ai\/nyheder\/\d{4}-\d{2}-\d{2}\/?$/.test(pathname);
const isAiNewsIndex = /^\/(?:da|en)\/ai\/nyheder\/?$/.test(pathname);
const isHomePage = /^\/(?:da|en)\/?$/.test(pathname);
const isContactPage = /^\/(?:da|en)\/kontakt\/?$/.test(pathname);
const isAboutPage = /^\/(?:da|en)\/om-os\/?$/.test(pathname);
const isLegalPage = /^\/(?:da|en)\/(?:juridisk|kontakt|om-os)(?:\/|$)/.test(pathname);
const isSectionIndex = /^\/(?:da|en)\/(?:ai|automationer|esp32|home-assistant|juridisk|produkter|sikkerhed)\/?$/.test(pathname)
  || /^\/(?:da|en)\/ai\/ai-cli\/?$/.test(pathname);
const shouldRenderArticleSchema = Boolean(entry?.data && !isHomePage && !isSectionIndex && !isLegalPage && !isAiNewsIndex && !isNotFoundPage);
const newsSources = Array.isArray(entry?.data?.news?.sources) ? entry.data.news.sources : [];
const robotsContent = isNotFoundPage
  ? "noindex, nofollow"
  : "max-image-preview:large, max-snippet:-1, max-video-preview:-1, noai, noimageai";
const defaultLanguagePath = pathname.startsWith("/en/") ? pathname.replace(/^\/en\//, "/da/") : pathname;
const defaultLanguageUrl = new URL(defaultLanguagePath, siteUrl).href;
const datePublished =
  toIsoDate(entry?.data?.date, entry?.data?.lastUpdated, lastUpdated) || "2024-01-01T00:00:00.000Z";
const dateModified = toIsoDate(entry?.data?.updated, entry?.data?.lastUpdated, lastUpdated, entry?.data?.date);
const searchUrl = lang === "da"
  ? `${siteUrl}/da/?search={search_term_string}`
  : `${siteUrl}/en/?search={search_term_string}`;
const aiNewsRssHref = lang === "da" ? `${siteUrl}/da/ai/nyheder/rss.xml` : `${siteUrl}/en/ai/news/rss.xml`;

const starlightHead = (starlightRoute?.head ?? []) as HeadEntry[];

const upsertMeta = (key: "name" | "property", value: string, content: string | null) => {
  if (!content) return;
  const existing = starlightHead.find((item) => item.tag === "meta" && item.attrs?.[key] === value);
  if (existing?.attrs) {
    existing.attrs.content = content;
  } else {
    starlightHead.push({ tag: "meta", attrs: { [key]: value, content } });
  }
};

const addLink = (attrs: Record<string, string>) => {
  const exists = starlightHead.some(
    (item) =>
      item.tag === "link" &&
      item.attrs?.rel === attrs.rel &&
      item.attrs?.href === attrs.href &&
      item.attrs?.hreflang === attrs.hreflang &&
      item.attrs?.type === attrs.type
  );
  if (!exists) starlightHead.push({ tag: "link", attrs });
};

if (entry?.data || isNotFoundPage) {
  upsertMeta("name", "description", description);
  upsertMeta("property", "og:description", description);
  upsertMeta("property", "og:type", isHomePage || isAiNewsIndex || isNotFoundPage ? "website" : "article");
  upsertMeta("property", "og:locale", openGraphLocale);
  upsertMeta("property", "og:locale:alternate", alternateOpenGraphLocale);
  upsertMeta("property", "og:image:alt", "SmartBolig.net");
  upsertMeta("name", "twitter:title", title);
  upsertMeta("name", "twitter:description", description);
  upsertMeta("name", "twitter:image:alt", "SmartBolig.net");
}

if (isAiNewsPage) {
  upsertMeta("property", "og:image", aiNewsSocialImageUrl);
  upsertMeta("property", "og:image:width", "1200");
  upsertMeta("property", "og:image:height", "630");
  upsertMeta(
    "property",
    "og:image:alt",
    lang === "da" ? "SmartBolig.net AI-nyheder" : "SmartBolig.net AI News"
  );
  upsertMeta("name", "twitter:image", aiNewsSocialImageUrl);
  upsertMeta(
    "name",
    "twitter:image:alt",
    lang === "da" ? "SmartBolig.net AI-nyheder" : "SmartBolig.net AI News"
  );
  addLink({
    rel: "alternate",
    type: "application/rss+xml",
    title: lang === "da" ? "SmartBolig.net AI-nyheder" : "SmartBolig.net AI News",
    href: aiNewsRssHref,
  });
}

if (entry?.data || isNotFoundPage) {
  addLink({
    rel: "alternate",
    hreflang: "x-default",
    href: defaultLanguageUrl,
  });
}

if (isAiNewsArticle) {
  upsertMeta("property", "article:published_time", datePublished);
  upsertMeta("property", "article:modified_time", dateModified || datePublished);
  upsertMeta("property", "article:section", "AI News");
}

// Organization Schema (appears on all pages)
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  name: "SmartBolig.net",
  url: siteUrl,
  logo: {
    "@type": "ImageObject",
    url: organizationLogoUrl,
    width: 1200,
    height: 270
  },
  description: lang === "da" 
    ? "Dansk guide til smart home med Home Assistant, ESP32 og Zigbee"
    : "Danish smart home guide with Home Assistant, ESP32 and Zigbee",
  sameAs: [
    "https://github.com/Hovborg/smartbolig-starlight"
  ]
};

// WebSite Schema with SearchAction
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  name: "SmartBolig.net",
  url: siteUrl,
  publisher: {
    "@id": `${siteUrl}/#organization`
  },
  inLanguage: [languageCode],
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: searchUrl
    },
    "query-input": "required name=search_term_string"
  }
};

const pathParts = pathname.split('/').filter(Boolean);
const localizedPathParts = pathParts[0] === "da" || pathParts[0] === "en" ? pathParts.slice(1) : pathParts;
const breadcrumbLabels: Record<string, Record<string, string>> = {
  da: {
    ai: "AI",
    "ai-cli": "AI CLI'er",
    nyheder: "AI-nyheder",
    automationer: "Automationer",
    esp32: "ESP32",
    "home-assistant": "Home Assistant",
    juridisk: "Juridisk",
    produkter: "Produkter",
    sikkerhed: "Sikkerhed",
    kontakt: "Kontakt",
    "om-os": "Om SmartBolig.net",
  },
  en: {
    ai: "AI",
    "ai-cli": "AI CLIs",
    nyheder: "AI News",
    automationer: "Automations",
    esp32: "ESP32",
    "home-assistant": "Home Assistant",
    juridisk: "Legal",
    produkter: "Products",
    sikkerhed: "Security",
    kontakt: "Contact",
    "om-os": "About SmartBolig.net",
  },
};
const formatBreadcrumbPart = (part: string) =>
  breadcrumbLabels[lang]?.[part] || part.replace(/-/g, " ").replace(/\b\w/g, (letter) => letter.toUpperCase());

// BreadcrumbList Schema for navigation
const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: lang === "da" ? "Forside" : "Home",
    item: `${siteUrl}/${lang}/`,
  },
  ...localizedPathParts.map((part, index) => {
    const path = `/${[lang, ...localizedPathParts.slice(0, index + 1)].join("/")}/`;
    const isLast = index === localizedPathParts.length - 1;
    const name = isLast ? title : formatBreadcrumbPart(part);

    return {
      "@type": "ListItem",
      position: index + 2,
      name,
      item: `${siteUrl}${path}`
    };
  })
];

const breadcrumbSchema = breadcrumbItems.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems
} : null;

const webPageType = isAiNewsIndex || isSectionIndex
  ? "CollectionPage"
  : isContactPage
    ? "ContactPage"
    : isAboutPage
      ? "AboutPage"
      : "WebPage";

const defaultSchemaImage = {
  "@type": "ImageObject",
  url: defaultSocialImageUrl,
  width: 1200,
  height: 630
};

const webPageSchema = entry?.data || isNotFoundPage ? {
  "@context": "https://schema.org",
  "@type": webPageType,
  "@id": `${pageUrl}#webpage`,
  name: title,
  description,
  url: pageUrl,
  inLanguage: languageCode,
  dateModified: dateModified || datePublished,
  isPartOf: {
    "@id": `${siteUrl}/#website`
  },
  publisher: {
    "@id": `${siteUrl}/#organization`
  },
  image: isAiNewsPage
    ? aiNewsSchemaImages.map((image) => ({
        "@type": "ImageObject",
        ...image,
      }))
    : defaultSchemaImage,
  ...(isAiNewsIndex && {
    mainEntity: {
      "@type": "DataFeed",
      name: lang === "da" ? "SmartBolig.net AI-nyheder" : "SmartBolig.net AI News",
      url: aiNewsRssHref,
    },
  }),
} : null;

const aiNewsKeywords = lang === "da"
  ? ["AI-nyheder", "OpenAI Codex", "Claude Code", "Gemini CLI", "AI CLI", "API-priser"]
  : ["AI News", "OpenAI Codex", "Claude Code", "Gemini CLI", "AI CLI", "API pricing"];

const articleSchema = shouldRenderArticleSchema ? {
  "@context": "https://schema.org",
  "@type": isAiNewsArticle ? "NewsArticle" : "TechArticle",
  "@id": `${pageUrl}#article`,
  headline: title,
  description: description,
  url: pageUrl,
  inLanguage: languageCode,
  datePublished: datePublished,
  dateModified: dateModified || datePublished,
  ...(isAiNewsArticle && {
    articleSection: "AI News",
    keywords: aiNewsKeywords,
    genre: "AI news briefing",
    isAccessibleForFree: true,
  }),
  ...(newsSources.length > 0 && {
    citation: newsSources.map((url: string) => ({
      "@type": "CreativeWork",
      url,
    })),
  }),
  isPartOf: {
    "@id": `${siteUrl}/#website`
  },
  author: {
    "@id": `${siteUrl}/#organization`
  },
  publisher: {
    "@id": `${siteUrl}/#organization`
  },
  image: isAiNewsArticle
    ? aiNewsSchemaImages.map((image) => ({
        "@type": "ImageObject",
        ...image,
      }))
    : defaultSchemaImage,
  mainEntityOfPage: {
    "@id": `${pageUrl}#webpage`
  }
} : null;

// Combine all schemas
const graphItems = [organizationSchema, websiteSchema];
if (webPageSchema) {
  graphItems.push(webPageSchema);
}
if (breadcrumbSchema) {
  graphItems.push(breadcrumbSchema);
}
if (articleSchema) {
  graphItems.push(articleSchema);
}

const combinedSchema = {
  "@context": "https://schema.org",
  "@graph": graphItems
};
---

<Default {...Astro.props} />

<!-- Preload LCP hero image for splash pages -->
{Astro.url.pathname.match(/^\/(da|en)\/?$/) && (
  <>
    <link rel="preload" as="image" href="/images/hero/front.webp" type="image/webp" fetchpriority="high" />
  </>
)}

<!-- Content Protection Meta Tags -->
<meta name="robots" content={robotsContent} />

<!-- Copyright information -->
<meta name="copyright" content="SmartBolig.net" />
<meta name="author" content="SmartBolig.net" />

<script type="application/ld+json" set:html={JSON.stringify(combinedSchema)} />
