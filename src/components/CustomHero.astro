---
// CustomHero.astro — homepage hero (markup only).
// All styling lives in HomeStyles.astro (global, home-only) under .home-hero*.
interface Props {
  title?: string;
  tagline?: string;
  image?: string;
  imageAlt?: string;
  badge?: string;
  primaryLink?: string;
  primaryText?: string;
  secondaryLink?: string;
  secondaryText?: string;
}

// Locale-aware defaults so the hero also works on /en/ without explicit props.
const lang = Astro.url.pathname.startsWith("/en/") ? "en" : "da";
const defaults = lang === "en"
  ? {
      title: "A smarter home you can understand and control",
      tagline: "Practical guides to Home Assistant, ESPHome and automation — with local control and privacy in focus.",
      badge: "Independent, practical guides",
      imageAlt: "Illustration of a smart home: a Home Assistant dashboard with temperature, lighting and security controls.",
      primaryLink: "/en/start-here/",
      primaryText: "Start here",
      secondaryLink: "/en/home-assistant/",
      secondaryText: "Explore guides",
    }
  : {
      title: "Et smartere hjem, du selv forstår og styrer",
      tagline: "Praktiske guides til Home Assistant, ESPHome og automation — med lokal kontrol og privatliv i fokus.",
      badge: "Uafhængige, praktiske guides",
      imageAlt: "Illustration af et smart hjem: et Home Assistant-dashboard med temperatur, lys og sikkerhed.",
      primaryLink: "/da/start-her/",
      primaryText: "Start her",
      secondaryLink: "/da/home-assistant/",
      secondaryText: "Find guides",
    };

const {
  title = defaults.title,
  tagline = defaults.tagline,
  image = "/images/hero/front.webp",
  imageAlt = defaults.imageAlt,
  badge = defaults.badge,
  primaryLink = defaults.primaryLink,
  primaryText = defaults.primaryText,
  secondaryLink = defaults.secondaryLink,
  secondaryText = defaults.secondaryText,
} = Astro.props;
---

<section class="home-hero" aria-labelledby="home-hero-title">
  <div class="home-hero__inner">
    <div class="home-hero__text home-reveal">
      <span class="home-hero__badge"><span class="dot" aria-hidden="true"></span>{badge}</span>
      <h1 id="home-hero-title">{title}</h1>
      <p class="home-hero__tagline">{tagline}</p>
      <div class="home-hero__cta">
        <a href={primaryLink} class="home-btn home-btn--primary">{primaryText}</a>
        <a href={secondaryLink} class="home-btn home-btn--ghost">{secondaryText}</a>
      </div>
    </div>
    <div class="home-hero__media home-reveal home-reveal-2">
      <div class="home-hero__frame">
        <img
          src={image}
          alt={imageAlt}
          width="1535"
          height="1023"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
