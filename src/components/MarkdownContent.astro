---
// Custom MarkdownContent that adds Giscus comments after article content
import Default from '@astrojs/starlight/components/MarkdownContent.astro';
import Giscus from './Giscus.astro';

const pathname = Astro.url.pathname;
const isAiNewsArticle = /^\/(?:da|en)\/ai\/nyheder\/\d{4}-\d{2}-\d{2}\/?$/.test(pathname);
let starlightRoute: typeof Astro.locals.starlightRoute | null = null;

try {
  starlightRoute = Astro.locals.starlightRoute;
} catch {
  starlightRoute = null;
}

const entry = Astro.props.entry || starlightRoute?.entry;
const heroImage = isAiNewsArticle ? entry?.data?.heroImage : null;
---

{heroImage && (
  <figure class="ai-news-hero">
    <img
      src={heroImage.src}
      alt={heroImage.alt}
      width="1200"
      height="630"
      decoding="async"
      loading="eager"
    />
    {heroImage.caption && <figcaption>{heroImage.caption}</figcaption>}
  </figure>
)}
<Default><slot /></Default>
<Giscus />

<style>
  :global(.ai-news-hero) {
    margin: 0 0 1.5rem;
  }

  :global(.ai-news-hero img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    background: #071311;
  }

  :global(.ai-news-hero figcaption) {
    margin-top: 0.5rem;
    color: var(--sl-color-gray-3);
    font-size: 0.875rem;
    line-height: 1.4;
  }
</style>
