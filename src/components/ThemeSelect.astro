---
const isDa = Astro.currentLocale === "da";
const label = isDa ? "Skift mellem lys og mørk tilstand" : "Toggle light and dark theme";
---

<theme-toggle>
  <button type="button" aria-label={label} title={label}>
    <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24">
      <path class="moon" d="M20.7 15.2A8 8 0 0 1 8.8 3.3 9 9 0 1 0 20.7 15.2Z" />
      <circle class="sun" cx="12" cy="12" r="4" />
      <path class="rays" d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4" />
    </svg>
  </button>
</theme-toggle>

<script>
  class SmartBoligThemeToggle extends HTMLElement {
    connectedCallback() {
      this.querySelector("button")?.addEventListener("click", () => {
        const next = document.documentElement.dataset.theme === "light" ? "dark" : "light";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("starlight-theme", next);
      });
    }
  }
  if (!customElements.get("theme-toggle")) customElements.define("theme-toggle", SmartBoligThemeToggle);
</script>

<style>
  theme-toggle { display: grid; place-items: center; }
  button {
    display: grid;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    place-items: center;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--sl-color-text);
    cursor: pointer;
  }
  button:hover { color: var(--sl-color-accent-high); }
  button:focus-visible { outline: 3px solid var(--sl-color-accent-high); outline-offset: 2px; }
  svg { fill: none; stroke: currentColor; stroke-linecap: round; stroke-linejoin: round; stroke-width: 1.8; }
  .sun, .rays { display: none; }
  :global(html[data-theme="light"]) .moon { display: none; }
  :global(html[data-theme="light"]) :is(.sun, .rays) { display: initial; }
  @media (max-width: 50rem) {
    :global(.mobile-preferences) theme-toggle { display: none; }
  }
</style>
