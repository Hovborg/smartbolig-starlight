---
// Homepage-only design system: "editorial smart-home field guide".
// All selectors are scoped to .home-* surfaces; nothing leaks to guide pages.
---

<style is:global>
  :root {
    --home-bg: #0a0e13;
    --home-panel: #10161e;
    --home-line: rgba(196, 214, 231, 0.16);
    --home-line-strong: rgba(103, 232, 249, 0.45);
    --home-text: #f3f7fa;
    --home-muted: #a9b8c6;
    --home-cyan: #67e8f9;
    --home-green: #6ce9a6;
    --home-warm: #e8b98a;
    --home-focus: #f8d477;
    --home-serif: "Charter", "Bitstream Charter", "Sitka Text", Cambria, Georgia, serif;
    --home-mono: ui-monospace, "SF Mono", "Cascadia Code", Menlo, monospace;
    --home-width: 1080px;
  }

  html[data-theme="light"] {
    --home-panel: #ffffff;
    --home-line: rgba(23, 33, 43, 0.18);
    --home-line-strong: rgba(8, 121, 138, 0.55);
    --home-text: #16212c;
    --home-muted: #4d6070;
    --home-cyan: #08798a;
    --home-green: #12734a;
    --home-warm: #8a5a2b;
    --home-focus: #8a4b00;
  }

  .sl-markdown-content :is(.home-hero, .home-portal, .home-section, .home-closing) { margin-top: 0; }
  .content-panel:has(> .sl-container > h1#_top) { display: none; }

  /* The theme paints headings with a gradient and counts list items inside
     sl-markdown-content; both must stay out of the homepage surfaces. */
  .sl-markdown-content .home-portal :is(h1, h2, h3) {
    background: none;
    -webkit-text-fill-color: currentColor;
  }
  .sl-markdown-content .home-portal li::before { content: none; }
  .sl-markdown-content .home-portal li::marker { content: none; }
  .sl-markdown-content .home-portal :is(ul, ol) { padding-inline-start: 0; }

  .home-portal { color: var(--home-text); }
  .home-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 0.9rem;
    color: var(--home-cyan);
    font-family: var(--home-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .home-eyebrow .dot {
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--home-green);
    box-shadow: 0 0 0 0.22rem rgba(108, 233, 166, 0.14);
  }

  /* ===== Hero ===== */
  .home-hero {
    position: relative;
    overflow: clip;
    padding: clamp(2.5rem, 6vw, 5.5rem) 0 clamp(2.75rem, 6vw, 5rem);
    background:
      radial-gradient(ellipse at 12% 8%, rgba(103, 232, 249, 0.09), transparent 42%),
      radial-gradient(ellipse at 88% 90%, rgba(232, 185, 138, 0.07), transparent 38%);
  }
  .home-hero::after {
    position: absolute;
    inset: auto 0 0;
    height: 1px;
    content: "";
    background: linear-gradient(90deg, transparent, var(--home-line-strong), transparent);
  }
  .home-hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(340px, 0.98fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    width: min(calc(100% - 2rem), var(--home-width));
    margin-inline: auto;
  }
  .home-hero h1 {
    margin: 0;
    background: none;
    -webkit-text-fill-color: currentColor;
    color: var(--home-text);
    font-family: var(--home-serif);
    font-size: clamp(2.3rem, 5vw, 3.9rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }
  .home-hero__line { display: block; }
  .home-hero__line:last-child { color: var(--home-cyan); }
  .home-hero__tagline {
    max-width: 46ch;
    margin: 1.3rem 0 0;
    color: var(--home-muted);
    font-size: clamp(1rem, 1.6vw, 1.14rem);
    line-height: 1.65;
  }
  .home-hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
    margin-top: 1.7rem;
  }
  .home-hero__frame {
    border: 1px solid var(--home-line);
    border-radius: 1.1rem;
    padding: 0.45rem;
    background: rgba(255, 255, 255, 0.03);
    box-shadow: 0 1.4rem 3.5rem rgba(0, 0, 0, 0.35);
  }
  html[data-theme="light"] .home-hero__frame {
    background: #fff;
    box-shadow: 0 1rem 2.5rem rgba(23, 33, 43, 0.14);
  }
  .home-hero__frame picture { display: block; }
  .home-hero__frame img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    border-radius: 0.75rem;
    object-fit: cover;
  }

  /* ===== Shared section scaffolding ===== */
  .home-section {
    width: min(calc(100% - 2rem), var(--home-width));
    margin: clamp(3.25rem, 7vw, 5.5rem) auto;
  }
  .home-section__heading { max-width: 700px; margin-bottom: clamp(1.5rem, 3vw, 2.25rem); }
  .home-section__heading h2, .home-closing h2 {
    margin: 0;
    background: none;
    -webkit-text-fill-color: currentColor;
    color: var(--home-text);
    font-family: var(--home-serif);
    font-size: clamp(1.6rem, 3.2vw, 2.35rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.12;
    text-wrap: balance;
  }
  .home-section__heading > p:last-child, .home-closing > p {
    max-width: 60ch;
    margin: 0.9rem 0 0;
    color: var(--home-muted);
    line-height: 1.6;
  }

  .home-text-link {
    color: var(--home-cyan);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.3em;
  }
  .home-tag {
    margin: 0;
    color: var(--home-warm);
    font-family: var(--home-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  /* ===== Goal navigator ===== */
  .home-navigator__beginner {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.6rem 2rem;
    margin-bottom: 1.9rem;
    padding: 1.1rem 1.25rem;
    border-left: 3px solid var(--home-green);
    border-radius: 0 0.7rem 0.7rem 0;
    background: linear-gradient(120deg, rgba(108, 233, 166, 0.09), rgba(103, 232, 249, 0.04));
  }
  html[data-theme="light"] .home-navigator__beginner {
    background: linear-gradient(120deg, rgba(18, 115, 74, 0.08), rgba(8, 121, 138, 0.04));
  }
  .home-navigator__beginner p { margin: 0; max-width: 58ch; color: var(--home-muted); line-height: 1.55; }
  .home-navigator__beginner strong { display: block; color: var(--home-text); font-size: 1.02rem; }
  .home-navigator__rows { margin: 0; padding: 0; list-style: none; border-top: 1px solid var(--home-line); }
  .home-navigator__rows li { margin: 0; border-bottom: 1px solid var(--home-line); }
  .home-navigator__rows a {
    display: grid;
    grid-template-columns: minmax(11rem, 16rem) 1fr auto;
    gap: 0.35rem 2rem;
    align-items: baseline;
    padding: 1.05rem 0.35rem;
    color: inherit;
    text-decoration: none;
  }
  .home-navigator__rows h3 {
    margin: 0;
    font-size: 1.06rem;
    font-weight: 700;
    color: var(--home-text);
  }
  .home-navigator__rows p { margin: 0; color: var(--home-muted); line-height: 1.5; }
  .home-navigator__arrow { color: var(--home-cyan); font-weight: 700; }

  /* ===== Field guide ===== */
  .home-fieldguide {
    padding: clamp(1.75rem, 4vw, 3rem);
    border: 1px solid var(--home-line);
    border-radius: 1.2rem;
    background: linear-gradient(135deg, rgba(103, 232, 249, 0.06), rgba(232, 185, 138, 0.035));
  }
  html[data-theme="light"] .home-fieldguide {
    background: linear-gradient(135deg, rgba(8, 121, 138, 0.05), rgba(138, 90, 43, 0.04));
  }
  .home-fieldguide__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
    margin: 0 0 1.6rem;
    padding: 0;
    list-style: none;
  }
  .home-fieldguide__steps li { margin: 0; padding-top: 0.9rem; border-top: 1px solid var(--home-line); }
  .home-fieldguide__stage {
    display: block;
    color: var(--home-warm);
    font-family: var(--home-serif);
    font-size: 1.9rem;
    font-style: italic;
    line-height: 1;
  }
  .home-fieldguide__steps h3 { margin: 0.55rem 0 0.4rem; font-size: 1.05rem; color: var(--home-text); }
  .home-fieldguide__steps p { margin: 0; color: var(--home-muted); line-height: 1.55; }

  /* ===== Featured guides ===== */
  .home-featured__layout {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: clamp(1.75rem, 4vw, 3.5rem);
    align-items: start;
  }
  .home-featured__lead {
    padding-top: 1.1rem;
    border-top: 3px solid var(--home-cyan);
  }
  .home-featured__lead h3 { margin: 0.8rem 0 0.7rem; font-family: var(--home-serif); font-size: clamp(1.45rem, 2.6vw, 1.95rem); font-weight: 600; line-height: 1.15; }
  .home-featured__lead h3 a { color: var(--home-text); text-decoration: none; }
  .home-featured__lead > p:last-child { margin: 0; max-width: 50ch; color: var(--home-muted); line-height: 1.6; }
  .home-featured__list { margin: 0; padding: 0; list-style: none; border-top: 1px solid var(--home-line); }
  .home-featured__list li { margin: 0; padding: 1rem 0.15rem; border-bottom: 1px solid var(--home-line); }
  .home-featured__list h3 { margin: 0.3rem 0 0.25rem; font-size: 1.04rem; }
  .home-featured__list h3 a { color: var(--home-text); text-decoration: none; }
  .home-featured__list p:last-child { margin: 0; color: var(--home-muted); line-height: 1.5; }

  /* ===== Trust & evidence ===== */
  .home-trust__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.4rem, 3vw, 2.25rem) clamp(1.75rem, 4vw, 3.5rem);
    margin: 0;
  }
  .home-trust__item { padding-top: 0.9rem; border-top: 1px solid var(--home-line); }
  .home-trust__item dt { color: var(--home-text); font-weight: 700; font-size: 1.02rem; }
  .home-trust__item dd { margin: 0.45rem 0 0; }
  .home-trust__item dd p { margin: 0 0 0.55rem; color: var(--home-muted); line-height: 1.55; }
  .home-trust__item .home-text-link { font-size: 0.92rem; }

  /* ===== Compact AI news ===== */
  .home-news-list { margin: 0; padding: 0; list-style: none; border-top: 1px solid var(--home-line); }
  .home-news-row {
    display: grid;
    grid-template-columns: 9.5rem 1fr auto;
    gap: 0.4rem 1.75rem;
    align-items: center;
    margin: 0;
    padding: 0.95rem 0.15rem;
    border-bottom: 1px solid var(--home-line);
  }
  .home-news-row time { color: var(--home-muted); font-family: var(--home-mono); font-size: 0.78rem; }
  .home-news-row__text h3 { margin: 0 0 0.25rem; font-size: 1.02rem; line-height: 1.3; }
  .home-news-row__text h3 a { color: var(--home-text); text-decoration: none; }
  .home-news-row__text p {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    color: var(--home-muted);
    line-height: 1.5;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }
  .home-news-row__thumb {
    width: 6.5rem;
    height: auto;
    border: 1px solid var(--home-line);
    border-radius: 0.45rem;
    object-fit: cover;
  }
  .home-news-actions { display: flex; flex-wrap: wrap; gap: 1.25rem; margin-top: 1.1rem; }
  .home-news-actions a { color: var(--home-muted); font-weight: 700; text-underline-offset: 0.25em; }
  .home-news-empty { color: var(--home-muted); }

  /* ===== Closing ===== */
  .home-closing {
    width: min(calc(100% - 2rem), var(--home-width));
    margin: clamp(3.25rem, 7vw, 5.5rem) auto;
    padding: clamp(1.9rem, 5vw, 3.5rem);
    border: 1px solid var(--home-line-strong);
    border-radius: 1.2rem;
    background:
      radial-gradient(circle at 85% 15%, rgba(108, 233, 166, 0.09), transparent 32%),
      linear-gradient(135deg, #101d26, #0f151d);
  }
  html[data-theme="light"] .home-closing { background: linear-gradient(135deg, #eefbfc, #f6f9fa); }
  .home-closing__actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.6rem; }

  /* ===== Buttons & focus ===== */
  .home-btn {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    padding: 0.72rem 1.35rem;
    border: 1px solid transparent;
    border-radius: 0.65rem;
    font-weight: 800;
    text-decoration: none;
  }
  .home-btn--primary { background: var(--home-cyan); color: #06222b; }
  html[data-theme="light"] .home-btn--primary { color: #ffffff; }
  .home-btn--ghost { border-color: var(--home-line); background: rgba(255, 255, 255, 0.035); color: var(--home-text); }
  html[data-theme="light"] .home-btn--ghost { background: #fff; }
  .home-portal :is(a, button):focus-visible,
  .home-hero a:focus-visible {
    outline: 3px solid var(--home-focus);
    outline-offset: 3px;
  }

  /* ===== Motion (opt-in only) ===== */
  @media (prefers-reduced-motion: no-preference) {
    .home-btn, .home-navigator__rows a, .home-navigator__arrow { transition: transform 160ms ease, background-color 160ms ease; }
    .home-btn:hover { transform: translateY(-2px); }
    .home-navigator__rows a:hover { background: rgba(255, 255, 255, 0.03); }
    html[data-theme="light"] .home-navigator__rows a:hover { background: rgba(23, 33, 43, 0.04); }
    .home-navigator__rows a:hover .home-navigator__arrow { transform: translateX(4px); }
  }

  /* ===== Responsive ===== */
  @media (max-width: 900px) {
    .home-hero__inner { grid-template-columns: 1fr; gap: 1.9rem; }
    .home-featured__layout { grid-template-columns: 1fr; }
    .home-fieldguide__steps { grid-template-columns: 1fr; gap: 0; }
    .home-fieldguide__steps li { display: grid; grid-template-columns: 2.6rem 1fr; column-gap: 0.9rem; padding-block: 0.95rem; }
    .home-fieldguide__stage { grid-row: 1 / span 2; font-size: 1.6rem; }
    .home-fieldguide__steps h3 { margin-top: 0.1rem; }
    .home-navigator__rows a { grid-template-columns: 1fr auto; }
    .home-navigator__rows p { grid-column: 1 / -1; }
  }
  @media (max-width: 620px) {
    .home-hero__inner, .home-section, .home-closing { width: min(calc(100% - 1.25rem), var(--home-width)); }
    .home-hero { padding-top: 1.9rem; padding-bottom: 2.25rem; }
    .home-hero h1 { font-size: clamp(2.05rem, 9.5vw, 2.6rem); }
    .home-hero__tagline { margin-top: 1rem; }
    .home-hero__cta { align-items: flex-start; margin-top: 1.4rem; }
    .home-section, .home-closing { margin-block: 2.4rem; }
    .home-section__heading { margin-bottom: 1.1rem; }
    /* Compact index on small screens: the row titles carry the navigation. */
    .home-navigator__rows p { display: none; }
    .home-navigator__rows a { padding-block: 0.85rem; }
    .home-navigator__beginner { margin-bottom: 1.4rem; padding: 0.95rem 1.05rem; }
    .home-fieldguide { padding: 1.25rem; }
    .home-fieldguide__steps { margin-bottom: 1.1rem; }
    .home-fieldguide__steps li { padding-block: 0.75rem; }
    .home-fieldguide__stage { font-size: 1.45rem; }
    .home-featured__list li { padding-block: 0.85rem; }
    .home-trust__grid { grid-template-columns: 1fr; gap: 1.05rem; }
    .home-trust__item dd p { font-size: 0.95rem; margin-bottom: 0.4rem; }
    .home-news-row { grid-template-columns: 1fr; gap: 0.3rem; align-items: start; padding-block: 0.8rem; }
    .home-news-row__thumb { display: none; }
    .home-news-row__text p { -webkit-line-clamp: 1; }
    .home-closing { padding: 1.6rem; }
    .home-closing__actions { flex-direction: column; align-items: stretch; margin-top: 1.2rem; }
  }
  @media (forced-colors: active) {
    .home-fieldguide, .home-closing, .home-hero__frame, .home-navigator__beginner { border: 1px solid CanvasText; }
    .home-btn { border: 1px solid LinkText; }
  }
</style>
