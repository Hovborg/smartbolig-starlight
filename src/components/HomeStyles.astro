---
// Homepage-only design system. All selectors are scoped to .home-* surfaces.
---

<style is:global>
  :root {
    --home-bg: #090d12;
    --home-panel: #111821;
    --home-panel-strong: #151f2a;
    --home-line: rgba(202, 220, 238, 0.14);
    --home-line-strong: rgba(103, 232, 249, 0.4);
    --home-text: #f4f8fb;
    --home-muted: #aebdca;
    --home-cyan: #67e8f9;
    --home-blue: #7cbcff;
    --home-green: #6ce9a6;
    --home-amber: #fedf89;
    --home-violet: #d8b4fe;
    --home-radius: 18px;
    --home-width: 1120px;
  }

  html[data-theme="light"] {
    --home-panel: #ffffff;
    --home-panel-strong: #f3f7f9;
    --home-line: rgba(23, 33, 43, 0.17);
    --home-line-strong: rgba(8, 121, 138, 0.55);
    --home-text: #17212b;
    --home-muted: #526474;
    --home-cyan: #08798a;
    --home-blue: #1769aa;
    --home-green: #147d4f;
    --home-amber: #805500;
    --home-violet: #7048a8;
  }
  html[data-theme="light"] .home-path { background: linear-gradient(145deg, #fff, #f5f9fa); }
  html[data-theme="light"] .home-guide,
  html[data-theme="light"] .home-news-card,
  html[data-theme="light"] .home-method-grid > div { background: var(--home-panel); }
  html[data-theme="light"] .home-news-card--lead { background: linear-gradient(145deg, #f7f0ff, #fff); }
  html[data-theme="light"] .home-cta { background: linear-gradient(135deg, #eefbfc, #f4f8fa); }
  html[data-theme="light"] .home-btn--ghost { background: #fff; }

  .sl-markdown-content :is(.home-hero, .home-portal, .home-section, .home-cta) { margin-top: 0; }
  .content-panel:has(> .sl-container > h1#_top) { display: none; }

  .home-hero {
    position: relative;
    overflow: clip;
    padding: clamp(3.5rem, 8vw, 7rem) 0 clamp(4rem, 8vw, 6.5rem);
    background:
      radial-gradient(circle at 18% 18%, rgba(34, 211, 238, 0.16), transparent 34%),
      radial-gradient(circle at 90% 70%, rgba(108, 233, 166, 0.09), transparent 30%);
  }
  .home-hero::after {
    position: absolute;
    inset: auto 0 0;
    height: 1px;
    content: "";
    background: linear-gradient(90deg, transparent, var(--home-line-strong), transparent);
  }
  .home-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(360px, 1.08fr);
    gap: clamp(2.5rem, 6vw, 5.5rem);
    align-items: center;
    width: min(calc(100% - 2rem), var(--home-width));
    margin-inline: auto;
  }
  .home-hero__badge, .home-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin: 0 0 1rem;
    color: var(--home-cyan);
    font-size: 0.77rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .home-hero__badge .dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: var(--home-green);
    box-shadow: 0 0 0 0.25rem rgba(108, 233, 166, 0.13);
  }
  .home-hero h1 {
    max-width: 15ch;
    margin: 0;
    color: var(--home-text);
    font-size: clamp(2.55rem, 5.7vw, 4.75rem);
    font-weight: 850;
    letter-spacing: -0.055em;
    line-height: 0.98;
    text-wrap: balance;
  }
  .home-hero__tagline {
    max-width: 52ch;
    margin: 1.5rem 0 0;
    color: var(--home-muted);
    font-size: clamp(1.05rem, 1.8vw, 1.22rem);
    line-height: 1.65;
  }
  .home-hero__cta, .home-actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.9rem; }
  .home-hero__frame {
    position: relative;
    padding: 0.7rem;
    border: 1px solid rgba(103, 232, 249, 0.23);
    border-radius: 1.4rem;
    background: rgba(17, 24, 33, 0.75);
    box-shadow: 0 2rem 6rem rgba(0, 0, 0, 0.48), 0 0 5rem rgba(34, 211, 238, 0.07);
    transform: perspective(1000px) rotateY(-2deg) rotateX(1deg);
  }
  .home-hero__frame::before {
    position: absolute;
    inset: 0.35rem 2rem auto;
    height: 1px;
    content: "";
    background: linear-gradient(90deg, transparent, rgba(103, 232, 249, 0.65), transparent);
  }
  .home-hero__frame img { display: block; width: 100%; height: auto; border-radius: 0.95rem; }

  .home-portal { color: var(--home-text); }
  .home-section {
    width: min(calc(100% - 2rem), var(--home-width));
    margin: clamp(4.5rem, 9vw, 7.5rem) auto;
  }
  .home-section__heading { max-width: 720px; margin-bottom: 2rem; }
  .home-section__heading h2, .home-cta h2 {
    margin: 0;
    color: var(--home-text);
    font-size: clamp(1.85rem, 3.8vw, 3rem);
    letter-spacing: -0.035em;
    line-height: 1.08;
    text-wrap: balance;
  }
  .home-section__heading > p:last-child, .home-cta > p {
    max-width: 62ch;
    margin: 1rem 0 0;
    color: var(--home-muted);
    font-size: 1.04rem;
    line-height: 1.65;
  }

  .home-path-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.9rem;
  }
  .home-path {
    --path-accent: var(--home-cyan);
    position: relative;
    grid-column: span 2;
    min-height: 230px;
    padding: 1.55rem;
    overflow: hidden;
    border: 1px solid var(--home-line);
    border-radius: var(--home-radius);
    background: linear-gradient(145deg, rgba(255,255,255,0.045), rgba(255,255,255,0.012));
    color: var(--home-text);
    text-decoration: none;
  }
  .home-path::after {
    position: absolute;
    inset: auto -20% -55% 25%;
    height: 75%;
    border-radius: 50%;
    background: var(--path-accent);
    content: "";
    filter: blur(55px);
    opacity: 0.08;
  }
  .home-path--featured { grid-column: span 3; }
  .home-path--featured + .home-path { grid-column: span 3; }
  .home-path--blue { --path-accent: var(--home-blue); }
  .home-path--green { --path-accent: var(--home-green); }
  .home-path--amber { --path-accent: var(--home-amber); }
  .home-path--violet { --path-accent: var(--home-violet); }
  .home-path__number { color: var(--path-accent); font: 800 0.78rem/1 ui-monospace, monospace; letter-spacing: 0.1em; }
  .home-path h3 { margin: 2rem 0 0.65rem; color: var(--home-text); font-size: 1.25rem; }
  .home-path p { margin: 0; color: var(--home-muted); line-height: 1.55; }
  .home-path__action { position: relative; z-index: 1; display: inline-block; margin-top: 1.25rem; color: var(--path-accent); font-weight: 750; }

  .home-start {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(440px, 1.2fr);
    gap: clamp(2rem, 6vw, 5rem);
    padding: clamp(2rem, 5vw, 4rem);
    border: 1px solid var(--home-line);
    border-radius: 1.6rem;
    background: linear-gradient(135deg, rgba(103,232,249,0.07), rgba(108,233,166,0.025));
  }
  .home-start .home-section__heading { margin: 0; }
  .home-step-list { display: grid; gap: 0; margin: 0; padding: 0; list-style: none; }
  .home-step-list li { display: grid; grid-template-columns: 2.7rem 1fr; gap: 1rem; padding: 1.15rem 0; border-bottom: 1px solid var(--home-line); }
  .home-step-list li:first-child { padding-top: 0; }
  .home-step-list li:last-child { border-bottom: 0; }
  .home-step-list > li > span { color: var(--home-cyan); font: 800 0.75rem/1.6 ui-monospace, monospace; }
  .home-step-list h3, .home-step-list p { margin: 0; }
  .home-step-list h3 { color: var(--home-text); font-size: 1rem; }
  .home-step-list p { margin-top: 0.3rem; color: var(--home-muted); line-height: 1.5; }
  .home-text-link { align-self: end; color: var(--home-cyan); font-weight: 750; text-decoration-thickness: 1px; text-underline-offset: 0.3em; }

  .home-guide-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.9rem; }
  .home-guide { padding: 1.4rem; border: 1px solid var(--home-line); border-radius: 0.95rem; background: var(--home-panel); }
  .home-guide > span { color: var(--home-cyan); font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; }
  .home-guide h3 { margin: 0.8rem 0 0.45rem; font-size: 1.08rem; }
  .home-guide h3 a { color: var(--home-text); text-decoration: none; }
  .home-guide p { margin: 0; color: var(--home-muted); line-height: 1.55; }

  .home-news-shell { padding-block: clamp(2rem, 5vw, 3.5rem); border-block: 1px solid var(--home-line); }
  .home-news-shell .home-section__heading { display: flex; max-width: none; align-items: end; justify-content: space-between; gap: 1.5rem; }
  .home-news-shell .home-section__heading .home-eyebrow { position: absolute; }
  .home-news-shell .home-section__heading h2 { padding-top: 1.6rem; }
  .home-news-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.9rem; }
  .home-news-card { display: flex; min-height: 245px; flex-direction: column; padding: 1.4rem; border: 1px solid var(--home-line); border-radius: var(--home-radius); background: var(--home-panel); }
  .home-news-card--lead { background: linear-gradient(145deg, rgba(216,180,254,0.09), rgba(255,255,255,0.025)); border-color: rgba(216,180,254,0.28); }
  .home-news-card time { color: var(--home-violet); font: 750 0.76rem/1.4 ui-monospace, monospace; }
  .home-news-card h3 { margin: 1rem 0 0.6rem; font-size: 1.14rem; line-height: 1.25; }
  .home-news-card h3 a { color: var(--home-text); text-decoration: none; }
  .home-news-card p { display: -webkit-box; margin: 0; overflow: hidden; color: var(--home-muted); line-height: 1.55; -webkit-box-orient: vertical; -webkit-line-clamp: 3; }
  .home-news-card__link { margin-top: auto; padding-top: 1rem; color: var(--home-violet); font-weight: 750; }
  .home-news-actions { display: flex; flex-wrap: wrap; gap: 1.25rem; margin-top: 1.2rem; }
  .home-news-actions a { color: var(--home-muted); font-weight: 700; text-underline-offset: 0.25em; }
  .home-news-empty { color: var(--home-muted); }
  .home-method { display: grid; grid-template-columns: minmax(280px, 0.8fr) 1.2fr; gap: 3rem; }
  .home-method-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.8rem; }
  .home-method-grid > div { padding: 1.3rem; border-top: 2px solid var(--home-cyan); background: rgba(255,255,255,0.025); }
  .home-method-grid h3, .home-method-grid p { margin: 0; }
  .home-method-grid h3 { color: var(--home-text); font-size: 1rem; }
  .home-method-grid p { margin-top: 0.55rem; color: var(--home-muted); line-height: 1.55; }

  .home-cta {
    width: min(calc(100% - 2rem), var(--home-width));
    margin: clamp(4.5rem, 9vw, 8rem) auto;
    padding: clamp(2.2rem, 6vw, 4.5rem);
    border: 1px solid rgba(103, 232, 249, 0.3);
    border-radius: 1.6rem;
    background: radial-gradient(circle at 80% 20%, rgba(108,233,166,0.1), transparent 28%), linear-gradient(135deg, #10202a, #101720);
  }
  .home-btn {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    padding: 0.78rem 1.25rem;
    border: 1px solid transparent;
    border-radius: 0.7rem;
    font-weight: 800;
    text-decoration: none;
  }
  .home-btn--primary { background: var(--home-cyan); color: #06222b; }
  .home-btn--ghost { border-color: var(--home-line); background: rgba(255,255,255,0.035); color: var(--home-text); }
  :is(.home-btn, .home-path, .home-guide a, .home-text-link):focus-visible { outline: 3px solid #f8d477; outline-offset: 4px; }

  @media (prefers-reduced-motion: no-preference) {
    .home-path, .home-btn, .home-guide { transition: transform 180ms ease, border-color 180ms ease, background-color 180ms ease; }
    .home-path:hover, .home-guide:hover { transform: translateY(-3px); border-color: var(--home-line-strong); }
    .home-btn:hover { transform: translateY(-2px); }
    .home-reveal { animation: home-rise 550ms cubic-bezier(.2,.8,.2,1) both; }
    .home-reveal-2 { animation-delay: 90ms; }
    @keyframes home-rise { from { opacity: 0; transform: translateY(14px); } }
  }

  @media (max-width: 900px) {
    .home-hero__inner, .home-start, .home-method { grid-template-columns: 1fr; }
    .home-hero__frame { transform: none; }
    .home-path, .home-path--featured, .home-path--featured + .home-path { grid-column: span 3; }
    .home-guide-grid, .home-news-grid { grid-template-columns: repeat(2, 1fr); }
    .home-method-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 620px) {
    .home-hero__inner, .home-section, .home-cta { width: min(calc(100% - 1.25rem), var(--home-width)); }
    .home-hero { padding-top: 3rem; }
    .home-hero__inner { gap: 2.5rem; }
    .home-hero h1 { font-size: clamp(2.35rem, 12vw, 3.25rem); }
    .home-path-grid, .home-guide-grid, .home-news-grid, .home-method-grid { grid-template-columns: 1fr; }
    .home-news-shell .home-section__heading { align-items: start; flex-direction: column; }
    .home-path, .home-path--featured, .home-path--featured + .home-path { grid-column: auto; min-height: 0; }
    .home-start { padding: 1.4rem; }
    .home-actions, .home-hero__cta { align-items: stretch; flex-direction: column; }
    .home-btn { width: 100%; }
  }
  @media (forced-colors: active) {
    .home-path, .home-guide, .home-start, .home-method-grid > div, .home-cta { border: 1px solid CanvasText; }
    .home-btn { border: 1px solid LinkText; }
  }
</style>
