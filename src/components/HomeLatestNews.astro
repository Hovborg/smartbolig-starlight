---
// Read-only adapter over the docs collection: renders the three latest AI News
// entries as a compact editorial list. Selection logic stays in home-news.ts.
import { getCollection } from "astro:content";
import { selectLatestNews, type NewsDocument, type NewsLocale } from "../lib/home-news";

interface Props {
  locale: NewsLocale;
}

const { locale } = Astro.props;
const isDa = locale === "da";
const docs = await getCollection("docs");
const latest = selectLatestNews(docs as unknown as NewsDocument[], locale);
const archiveHref = isDa ? "/da/ai/nyheder/" : "/en/ai/nyheder/";
const rssHref = isDa ? "/da/ai/nyheder/rss.xml" : "/en/ai/news/rss.xml";
const copy = isDa
  ? {
      archive: "Alle AI-nyheder",
      rss: "Følg via RSS",
      empty: "Der er ingen publicerede AI-nyheder endnu.",
    }
  : {
      archive: "All AI news",
      rss: "Follow via RSS",
      empty: "There are no published AI news articles yet.",
    };

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat(isDa ? "da-DK" : "en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
    timeZone: "UTC",
  }).format(date);

// ai-news-thumbs.mjs renders a 320x180 WebP next to every base PNG at build
// time, so the 160x90 list thumb never loads the full 1200x630 hero image.
const thumbSrc = (src: string) => src.replace(/\.png$/, "-thumb.webp");
---

<div class="home-latest-news">
  {
    latest.length > 0 ? (
      <ul class="home-news-list">
        {latest.map((item) => (
          <li class="home-news-row">
            <time datetime={item.dateString}>{formatDate(item.date)}</time>
            <div class="home-news-row__text">
              <h3><a href={item.href}>{item.title}</a></h3>
              <p>{item.description}</p>
            </div>
            {item.image && (
              <img
                class="home-news-row__thumb"
                src={thumbSrc(item.image.src)}
                alt=""
                width="160"
                height="90"
                loading="lazy"
                decoding="async"
              />
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p class="home-news-empty">{copy.empty}</p>
    )
  }
  <div class="home-news-actions">
    <a href={archiveHref}>{copy.archive}</a>
    <a href={rssHref}>{copy.rss}</a>
  </div>
</div>
